{
  "name": "pomodoro-visualizer",
  "version": "1.0.0",
  "productName": "Tomato",
  "description": "Desktop Pomodoro timer with macOS menu bar support.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "author": "Vivek Kumar",
  "license": "MIT",
  "build": {
    "appId": "com.vivekascoder.tomato",
    "productName": "Tomato",
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "assets/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "canvas": "^3.2.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.7",
    "typescript": "^5.7.2"
  }
}
